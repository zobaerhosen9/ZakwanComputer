{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Inventory product item",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "stock": { "type": "number" },
        "alertLimit": { "type": "number" },
        "sku": { "type": "string" },
        "shelf": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["name", "category", "buyPrice", "sellPrice", "stock", "alertLimit", "sku"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      },
      "required": ["name"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Client invoice receipt summary",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerMobile": { "type": "string" },
        "items": { "type": "array" },
        "subTotal": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "paid": { "type": "number" },
        "due": { "type": "number" },
        "date": { "type": "string" },
        "salesperson": { "type": "string" }
      },
      "required": ["customerName", "customerMobile", "items", "subTotal", "discount", "total", "paid", "due", "date", "salesperson"]
    },
    "Expense": {
      "title": "Expense",
      "description": "General shop expense",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["title", "category", "amount", "date"]
    },
    "Purchase": {
      "title": "Purchase",
      "description": "Stock purchase tracker",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "productsBought": { "type": "array" },
        "totalCost": { "type": "number" },
        "amountPaid": { "type": "number" },
        "dueAmount": { "type": "number" },
        "date": { "type": "string" }
      },
      "required": ["supplierId", "supplierName", "productsBought", "totalCost", "amountPaid", "dueAmount", "date"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Shop client details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "mobile": { "type": "string" },
        "address": { "type": "string" },
        "totalDue": { "type": "number" }
      },
      "required": ["name", "mobile", "totalDue"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Product wholesaler details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "totalDueToSupplier": { "type": "number" }
      },
      "required": ["name", "phone", "totalDueToSupplier"]
    },
    "ShopSettings": {
      "title": "ShopSettings",
      "description": "Shop customization info",
      "type": "object",
      "properties": {
        "shopName": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "currency": { "type": "string" },
        "vatRate": { "type": "number" }
      },
      "required": ["shopName", "address", "phone", "currency"]
    }
  },
  "firestore": {
    "products": { "schema": "Product", "description": "Inventory product list" },
    "categories": { "schema": "Category", "description": "Category folder taxonomy" },
    "sales": { "schema": "Sale", "description": "Customer invoice transactions" },
    "expenses": { "schema": "Expense", "description": "Operational cost entries" },
    "purchases": { "schema": "Purchase", "description": "Supplier purchase records" },
    "customers": { "schema": "Customer", "description": "Registered buyer accounts" },
    "suppliers": { "schema": "Supplier", "description": "Registered wholesalers" },
    "settings": { "schema": "ShopSettings", "description": "General customisation info" }
  }
}
